# ── LLM Backend ───────────────────────────────────────────────────────────────
# Choose your LLM backend:
#   ollama  = free local inference (default, requires Ollama running)
#   claude  = Anthropic Claude (requires ANTHROPIC_API_KEY)
#   openai  = OpenAI GPT (requires OPENAI_API_KEY)
LLM_BACKEND=ollama

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-5

# ── OpenAI (optional) ─────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Embeddings (runs locally, no API cost) ────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu   # cpu | cuda | mps

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
DEFAULT_COLLECTION=default

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=6
SIMILARITY_THRESHOLD=0.35
MMR_LAMBDA=0.5              # 1.0 = pure relevance, 0.0 = pure diversity
USE_RERANKER=true           # cross-encoder reranking (recommended)
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
USE_HYDE=false              # Hypothetical Document Embeddings (slower, better recall on asymmetric queries)
USE_MULTI_QUERY=false       # expand query into sub-queries (uses extra LLM tokens)
USE_HYBRID_SEARCH=true      # dense + BM25 hybrid search (recommended)
HYBRID_ALPHA=0.7            # weight for dense search (1-alpha for BM25)

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
USE_SEMANTIC_CHUNKING=false # semantic chunking (slower, smarter sentence-boundary splits)

# ── Generation ────────────────────────────────────────────────────────────────
MAX_TOKENS=1024
TEMPERATURE=0.2             # low = factual, high = creative

# ── Caching ───────────────────────────────────────────────────────────────────
ENABLE_CACHE=true
CACHE_SIMILARITY_THRESHOLD=0.95
CACHE_MAX_SIZE=500

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
CORS_ORIGINS=["*"]

# ── Contextual Retrieval (Anthropic Nov 2024) ─────────────────────────────────
# Prepends LLM-generated context to each chunk before embedding.
# Reduces retrieval failures by ~49%. Significantly increases ingest time.
USE_CONTEXTUAL_RETRIEVAL=false
CONTEXTUAL_RETRIEVAL_USE_HAIKU=true  # use claude-haiku-4-5 for cheaper contextual enrichment

# ── Web Search Fallback ───────────────────────────────────────────────────────
# Falls back to web search when CRAG confidence is below threshold.
WEB_SEARCH_FALLBACK=false
WEB_SEARCH_PROVIDER=tavily       # tavily | duckduckgo
TAVILY_API_KEY=your_tavily_key_here
CRAG_WEB_FALLBACK_THRESHOLD=0.4

# ── Langfuse Observability ────────────────────────────────────────────────────
# Get keys at https://cloud.langfuse.com — free tier available.
LANGFUSE_PUBLIC_KEY=pk-lf-your_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Agentic RAG ───────────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=8

# ── SQL / Structured Data ─────────────────────────────────────────────────────
# SQLAlchemy URL. Leave empty to disable SQL features.
# Examples: sqlite:///./data/mydb.db  |  postgresql://user:pass@host/db
SQL_DATABASE_URL=

# ── Security ──────────────────────────────────────────────────────────────────
ENABLE_PII_REDACTION=false       # regex PII redaction before embedding
ENABLE_PII_PRESIDIO=false        # ML-based PII (requires: pip install presidio-analyzer presidio-anonymizer)
ENABLE_INJECTION_DETECTION=true  # scan retrieved chunks for prompt injection patterns
ENABLE_AUDIT_LOG=true            # JSONL audit trail at data/audit_log.jsonl

# ── GraphRAG ──────────────────────────────────────────────────────────────────
GRAPHRAG_COMMUNITY_DETECTION=false  # build Louvain community summaries for global queries

# ── Sufficient Context (Google ICLR 2025) ────────────────────────────────────
# Scores context quality before every generation. Abstains if below threshold.
ENABLE_SUFFICIENT_CONTEXT=true
SUFFICIENT_CONTEXT_THRESHOLD=0.45  # abstain below this score [0-1]
SUFFICIENT_CONTEXT_SELF_RATING=false  # ask LLM to self-rate confidence (+~200ms)

# ── CoT-RAG (EMNLP 2025) ─────────────────────────────────────────────────────
COT_MAX_STEPS=4           # max reasoning steps to decompose a question into
COT_TOP_K_PER_STEP=3      # chunks to retrieve per reasoning step

# ── LightRAG (EMNLP 2025) ────────────────────────────────────────────────────
LIGHTRAG_MAX_LOW_LEVEL_HOPS=2     # graph traversal depth for entity-anchored retrieval
LIGHTRAG_MAX_COMMUNITIES=5        # max community summaries for thematic retrieval

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
